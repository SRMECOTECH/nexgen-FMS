# =====================================================================
# nextGen-FMS — configuration template.
#
# QUICK START (fresh clone):
#   1. Copy this file to .env          →  cp .env.example .env
#   2. Edit WAREHOUSE_URL below to point at YOUR MySQL server.
#   3. Start the backend — the database and every table are created
#      automatically on first startup (or from Settings → Initialize DB).
#
# Every value here can also be viewed/edited later from the Settings page
# in the UI (System → Settings). The .env file stays the single source of
# truth — the UI writes back to it.
# =====================================================================


# ---------------------------------------------------------------------
# 1) CORE — Excel source  →  local MySQL warehouse
# ---------------------------------------------------------------------

# Serve real data (not the in-memory mock fixtures).
USE_MOCK_DATA=false

# Hard-disable all Iceberg / MinIO catalog calls (no network attempts, no logs).
DISABLE_ICEBERG=true

# Warehouse (read + write). ONE SQLAlchemy URL selects the database.
# The database named here (nextgen_fms) is AUTO-CREATED on first startup —
# only the MySQL server itself must be running. Adjust user/password/host.
WAREHOUSE_URL=mysql+pymysql://root:root@127.0.0.1:3306/nextgen_fms

# Logical schema name for raw landing tables.
WAREHOUSE_RAW_SCHEMA=raw

# Ingestion SOURCE selection — INGEST_SOURCE = sample | iceberg
#   sample  -> reads the Excel feeds (sample_data/*.xlsx, data/*.xlsx). Works offline.
#   iceberg -> live neXgen-Lakehouse (see the commented Iceberg block below).
INGEST_SOURCE=sample

# ---------------------------------------------------------------------
# 1b) PORTS — backend 9001, frontend 6173 (override to anything free)
# ---------------------------------------------------------------------
FMS_BACKEND_HOST=0.0.0.0
FMS_BACKEND_PORT=9001
FMS_FRONTEND_PORT=6173

# Frontend → nextGen-FMS backend.
VITE_API_URL=http://localhost:9001/api/v1

# Frontend → smart-truck ML subscription API (Swagger link / raw-model buttons
# only; production traffic goes via the backend ML proxy at /api/v1/ml/*).
VITE_ML_API_URL=http://localhost:8001

# ---------------------------------------------------------------------
# 1c) SMART-TRUCK ML SUBSCRIPTION API — OPTIONAL
#     When unreachable, AI pages render demo data instead. Leave as-is
#     if you don't run smart-truck.
# ---------------------------------------------------------------------
ML_SERVICE_URL=http://localhost:8001
# Read-only link to smart-truck's MySQL DB (ETA city-name suggestions only).
SMART_TRUCK_DB_URL=mysql+pymysql://root:root@127.0.0.1:3306/smart_truck
# Subscription key sent as X-API-Key on every proxy call.
ML_API_KEY=sk_test_replace_me
# Per-call timeout (seconds) when the backend proxies a model call.
ML_PROXY_TIMEOUT=20
# Per-model timeout inside /ai/* — slower models fall back to demo data.
AI_MODEL_TIMEOUT=6

# ---------------------------------------------------------------------
# 1d) OSRM DISTANCE API — OPTIONAL
#     Route efficiency compares driven GPS distance to optimal road distance.
#     When unreachable the analyzer silently falls back to straight-line.
# ---------------------------------------------------------------------
OSRM_API_URL=http://localhost:7001
OSRM_API_TIMEOUT=15

# ---------------------------------------------------------------------
# 1e) AI INSIGHTS — Route Intelligence natural-language insights
#     INSIGHTS_PROVIDER = rule-based | gemini
#       gemini     -> real dynamic AI via Google Gemini (LangChain). Get a FREE
#                     key at https://aistudio.google.com ("Get API key"), paste
#                     it below (or on the Settings page), set provider=gemini.
#       rule-based -> no LLM. NOTE: the app has an LLM-ONLY insights policy —
#                     template output is never stored or shown as an "AI
#                     insight", so with this provider the insight feeds stay
#                     empty (metrics/charts all still work).
#     RECOMMENDED: set provider=gemini + a key so insights are generated.
# ---------------------------------------------------------------------
INSIGHTS_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
INSIGHTS_TEMPERATURE=0.4
INSIGHTS_TIMEOUT=20

# OPTIONAL — the Streamlit "Journey planner" section on :8501 (tab 🤖 AI
# Insights) can draft on-the-spot plans via OpenAI. Needs `pip install
# langchain-openai`. Everything else (incl. the insight feed) works without it.
OPENAI_API_KEY=


# ---------------------------------------------------------------------
# 2) ANALYTICS TUNABLES — speed bands & stop detection
# ---------------------------------------------------------------------

# A GPS ping faster than this (km/h) counts as MOVING; at/below it = stopped.
MOVING_KPH=2

# A ping faster than this (km/h) is flagged as OVER-SPEED (fleet policy).
OVERSPEED_KPH=60

# A standstill must last at least this many minutes to be recorded as a stop.
STOP_MIN_MINUTES=12

# DBSCAN radius (metres) that merges repeat visits into ONE geofence.
STOP_CLUSTER_EPS_M=250


# ---------------------------------------------------------------------
# 3) LOCATION ENRICHMENT — reverse-geocoding (Nominatim) + POI (Overpass)
# ---------------------------------------------------------------------

NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_DELAY=1.1
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_DELAY=1.1
POI_RADIUS_M=200


# =====================================================================
# DISABLED — not in use yet. Uncomment a block and fill values to enable.
# =====================================================================

# ---------- Neon Postgres (cloud warehouse — alternative to MySQL) ----------
# WAREHOUSE_URL=postgresql+psycopg://USER:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=require

# ---------- neXgen-Lakehouse base UI ----------
# LAKEHOUSE_BASE_URL=http://your-lakehouse-host:5173

# ---------- PyIceberg (REST catalog) ----------
# ICEBERG_CATALOG_URI=http://your-lakehouse-host:8181
# ICEBERG_WAREHOUSE=s3://nexgen-warehouse
# ICEBERG_NAMESPACE=telemetry
# ICEBERG_TOKEN=

# ---------- Live Iceberg ingestion source (used when INGEST_SOURCE=iceberg) ----------
# ICEBERG_REST_URI=http://localhost:8181
# ICEBERG_S3_ENDPOINT=http://localhost:9000
# ICEBERG_S3_ACCESS_KEY=
# ICEBERG_S3_SECRET_KEY=
# ICEBERG_S3_REGION=us-east-1

# ---------- S3 / MinIO (Iceberg storage layer) ----------
# S3_ENDPOINT=http://your-lakehouse-host:9000
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

# ---------- ClickHouse gateway (low-latency SQL) ----------
# CLICKHOUSE_HOST=your-lakehouse-host
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=telemetry

# ---------- Trino proxy (fallback SQL) ----------
# TRINO_HOST=your-lakehouse-host
# TRINO_PORT=8080
# TRINO_TOKEN=
